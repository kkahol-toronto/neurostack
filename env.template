# =============================================================================
# NeuroStack Azure Integration Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual Azure credentials
# cp env.template .env

# =============================================================================
# AZURE API MANAGEMENT (APIM) CONFIGURATION
# =============================================================================
# Your Azure API Management gateway endpoint (load balancer for OpenAI)
AZURE_OPENAI_ENDPOINT=https://your-apim-gateway.azure-api.net/

# Your Azure API Management subscription key
AZURE_OPENAI_KEY=your-apim-subscription-key-here

# Your model deployment name (e.g., gpt-4, gpt-4v, gpt-35-turbo)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Azure OpenAI API version (usually keep default)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# AZURE COGNITIVE SERVICES CONFIGURATION (APIM-based)
# =============================================================================
# Note: For APIM setup, Cognitive Services uses the same endpoint and key as OpenAI
# The system will automatically use GPT-4V for image analysis through the same APIM endpoint
AZURE_COGNITIVE_SERVICES_ENDPOINT=https://your-apim-gateway.azure-api.net/

# Your Azure API Management subscription key (same as OpenAI)
AZURE_COGNITIVE_SERVICES_KEY=your-apim-subscription-key-here

# =============================================================================
# AZURE FUNCTIONS CONFIGURATION
# =============================================================================
# Your Azure Functions app URL (found in Azure Portal)
AZURE_FUNCTIONS_URL=https://your-function-app-name.azurewebsites.net/api/

# Your Azure Functions function key (optional, for authentication)
AZURE_FUNCTIONS_KEY=your-function-key-here

# =============================================================================
# AZURE CONTAINER INSTANCES CONFIGURATION
# =============================================================================
# Your Azure subscription ID (found in Azure Portal)
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# Your Azure resource group name
AZURE_RESOURCE_GROUP=your-resource-group-name

# Your Azure region (e.g., eastus, westus, westeurope)
AZURE_LOCATION=eastus

# =============================================================================
# AZURE COSMOS DB CONFIGURATION (Optional)
# =============================================================================
# Your Azure Cosmos DB connection string
AZURE_COSMOS_DB_CONNECTION_STRING=mongodb://your-cosmos-db-account:your-key@your-cosmos-db-account.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@your-cosmos-db-account@

# Your Azure Cosmos DB database name
AZURE_COSMOS_DB_DATABASE=neurostack

# =============================================================================
# AZURE SERVICE BUS CONFIGURATION (Optional)
# =============================================================================
# Your Azure Service Bus connection string
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-service-bus-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key

# =============================================================================
# AZURE STORAGE CONFIGURATION (Optional)
# =============================================================================
# Your Azure Storage account connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-storage-account;AccountKey=your-storage-key;EndpointSuffix=core.windows.net

# Your Azure Storage container name
AZURE_STORAGE_CONTAINER=neurostack-data

# =============================================================================
# AZURE APPLICATION INSIGHTS (Optional)
# =============================================================================
# Your Azure Application Insights instrumentation key
AZURE_APPLICATION_INSIGHTS_KEY=your-instrumentation-key-here

# =============================================================================
# AZURE KEY VAULT (Optional - for secure credential management)
# =============================================================================
# Your Azure Key Vault URL
AZURE_KEY_VAULT_URL=https://your-key-vault-name.vault.azure.net/

# =============================================================================
# GENERAL AZURE CONFIGURATION
# =============================================================================
# Azure tenant ID (found in Azure Portal)
AZURE_TENANT_ID=your-tenant-id-here

# Azure client ID (if using service principal)
AZURE_CLIENT_ID=your-client-id-here

# Azure client secret (if using service principal)
AZURE_CLIENT_SECRET=your-client-secret-here

# =============================================================================
# NEUROSTACK SPECIFIC CONFIGURATION
# =============================================================================
# Enable/disable specific Azure services (true/false)
AZURE_ENABLE_OPENAI=true
AZURE_ENABLE_COGNITIVE_SERVICES=true
AZURE_ENABLE_FUNCTIONS=true
AZURE_ENABLE_CONTAINER_INSTANCES=true
AZURE_ENABLE_COSMOS_DB=false
AZURE_ENABLE_SERVICE_BUS=false
AZURE_ENABLE_STORAGE=false

# =============================================================================
# OTHER CLOUD PROVIDERS (for comparison)
# =============================================================================
# OpenAI Configuration (if not using Azure OpenAI)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GCP Configuration (if using GCP alongside Azure)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database URL (can use Azure SQL Database)
DATABASE_URL=postgresql://user:password@localhost/neurostack

# Redis Configuration
REDIS_URL=redis://localhost:6379

# =============================================================================
# LOGGING AND MONITORING
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable structured logging
ENABLE_STRUCTURED_LOGGING=true

# =============================================================================
# SECURITY
# =============================================================================
# Secret key for JWT tokens
SECRET_KEY=your-secret-key-here

# JWT algorithm
JWT_ALGORITHM=HS256

# =============================================================================
# NOTES
# =============================================================================
# 1. Replace all "your-*" values with your actual Azure credentials
# 2. Keep this file secure and never commit it to version control
# 3. Use Azure Key Vault for production environments
# 4. Enable only the services you need by setting AZURE_ENABLE_* flags
# 5. For production, consider using managed identities instead of API keys 