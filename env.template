# =============================================================================
# NEUROSTACK ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# 
# This template contains all environment variables used by the NeuroStack
# platform and the Banking Agent application.
#
# Copy this file to .env and fill in your actual values.
# DO NOT commit the .env file to version control (it's in .gitignore).
#
# =============================================================================

# =============================================================================
# AZURE OPENAI CONFIGURATION (REQUIRED)
# =============================================================================
# 
# These are the core Azure OpenAI settings required for the AI functionality.
# You can use either direct Azure OpenAI endpoints or APIM endpoints.

# Azure OpenAI Endpoint (Direct or APIM)
# Format: https://your-resource.openai.azure.com/ (Direct)
# Format: https://your-apim.azure-api.net/ (APIM)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI API Key
# Get this from Azure Portal > Your OpenAI Resource > Keys and Endpoint
AZURE_OPENAI_KEY=your_azure_openai_api_key_here

# Azure OpenAI API Version
# Recommended: 2024-02-15-preview (latest features)
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI Deployment Name
# The name of your GPT-4 or GPT-3.5 deployment in Azure OpenAI
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# =============================================================================
# AZURE COGNITIVE SERVICES (OPTIONAL)
# =============================================================================
# 
# Used for advanced AI features like image analysis, text analytics, etc.
# If using APIM, these should point to your APIM endpoint.

# Azure Cognitive Services Endpoint (APIM recommended)
# Format: https://your-apim.azure-api.net/
AZURE_COGNITIVE_SERVICES_ENDPOINT=https://your-apim.azure-api.net/

# Azure Cognitive Services Key (APIM key)
AZURE_COGNITIVE_SERVICES_KEY=your_apim_key_here

# =============================================================================
# AZURE COSMOS DB (OPTIONAL - FOR PERSISTENT MEMORY)
# =============================================================================
# 
# Used for persistent memory storage, query history, and learning.
# If not provided, the system will use in-memory storage.

# Azure Cosmos DB Connection String
# Format: AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=your-key;Database=neurostack
AZURE_COSMOS_DB_CONNECTION_STRING=AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=your-key;Database=neurostack

# =============================================================================
# AZURE FUNCTIONS (OPTIONAL)
# =============================================================================
# 
# Used for serverless function integration.

# Azure Functions URL
AZURE_FUNCTIONS_URL=https://your-function-app.azurewebsites.net/api/

# Azure Functions Key
AZURE_FUNCTIONS_KEY=your_function_key_here

# =============================================================================
# AZURE STORAGE (OPTIONAL)
# =============================================================================
# 
# Used for file storage and blob operations.

# Azure Storage Connection String
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# Azure Storage Container Name
AZURE_STORAGE_CONTAINER=neurostack-files

# =============================================================================
# AZURE SERVICE BUS (OPTIONAL)
# =============================================================================
# 
# Used for message queuing and event-driven architecture.

# Azure Service Bus Connection String
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key

# Azure Service Bus Namespace
AZURE_SERVICE_BUS_NAMESPACE=your-namespace

# =============================================================================
# EMAIL CONFIGURATION (OPTIONAL)
# =============================================================================
# 
# Used for sending automated emails from the banking agent.

# SMTP Server
SMTP_SERVER=smtp.gmail.com

# SMTP Port
SMTP_PORT=587

# Sender Email Address
SENDER_EMAIL=neurostackagent@gmail.com

# Sender Password (App password for Gmail)
SENDER_PASSWORD=your_app_password_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# 
# Core application settings for the NeuroStack platform.

# Server Host (for production, use 0.0.0.0)
HOST=0.0.0.0

# Server Port
PORT=8000

# Debug Mode (true for development, false for production)
DEBUG=false

# =============================================================================
# AI CONFIGURATION
# =============================================================================
# 
# AI-specific settings for reasoning and memory.

# Maximum context tokens for RAG (Retrieval-Augmented Generation)
RAG_MAX_CONTEXT_TOKENS=8000

# System prompt for the AI assistant
SYSTEM_PROMPT=You are an intelligent banking assistant powered by NeuroStack. You help with credit risk assessment, fraud detection, and customer analysis. Always provide clear, accurate, and helpful responses.

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# 
# Security and authentication settings.

# JWT Secret Key (generate a secure random key)
JWT_SECRET_KEY=your-super-secret-jwt-key-here

# JWT Algorithm
JWT_ALGORITHM=HS256

# JWT Expiration Time (in minutes)
JWT_EXPIRATION_MINUTES=1440

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# 
# Logging and monitoring settings.

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log File Path (optional)
LOG_FILE_PATH=logs/neurostack.log

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# 
# Performance and optimization settings.

# Maximum concurrent requests
MAX_CONCURRENT_REQUESTS=100

# Request timeout (in seconds)
REQUEST_TIMEOUT=30

# Memory cache size (in MB)
MEMORY_CACHE_SIZE=512

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# 
# Development-specific settings (not for production).

# Enable hot reload (for development)
HOT_RELOAD=true

# Enable CORS for development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# 
# Testing-specific settings.

# Test mode (enables mock data and test endpoints)
TEST_MODE=false

# Test database URL (for integration tests)
TEST_DATABASE_URL=sqlite:///./test.db

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# 
# Monitoring and observability settings.

# Enable health checks
ENABLE_HEALTH_CHECKS=true

# Health check interval (in seconds)
HEALTH_CHECK_INTERVAL=30

# Metrics collection (true/false)
ENABLE_METRICS=true

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# 
# Deployment and environment-specific settings.

# Environment (development, staging, production)
ENVIRONMENT=development

# Application name
APP_NAME=neurostack-banking-agent

# Version
APP_VERSION=1.0.0

# =============================================================================
# NOTES AND EXAMPLES
# =============================================================================
#
# 1. REQUIRED VARIABLES:
#    - AZURE_OPENAI_ENDPOINT
#    - AZURE_OPENAI_KEY
#    - AZURE_OPENAI_API_VERSION
#    - AZURE_OPENAI_DEPLOYMENT_NAME
#
# 2. RECOMMENDED FOR PRODUCTION:
#    - AZURE_COSMOS_DB_CONNECTION_STRING (for persistent memory)
#    - AZURE_COGNITIVE_SERVICES_ENDPOINT (for advanced AI features)
#    - JWT_SECRET_KEY (for authentication)
#    - SMTP_* variables (for email functionality)
#
# 3. APIM SETUP:
#    If using Azure API Management (APIM) for load balancing:
#    - Set AZURE_OPENAI_ENDPOINT to your APIM endpoint
#    - Set AZURE_OPENAI_KEY to your APIM key
#    - Set AZURE_COGNITIVE_SERVICES_ENDPOINT to your APIM endpoint
#    - Set AZURE_COGNITIVE_SERVICES_KEY to your APIM key
#
# 4. SECURITY:
#    - Never commit .env files to version control
#    - Use strong, unique keys for production
#    - Rotate keys regularly
#    - Use managed identities when possible
#
# 5. TROUBLESHOOTING:
#    - Run debug/check_neurostack_setup.py to verify configuration
#    - Check Azure Portal for correct endpoints and keys
#    - Ensure all required services are deployed and accessible
#
# ============================================================================= 